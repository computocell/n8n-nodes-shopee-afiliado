{
  "name": "n8n-nodes-shopee-affiliate",
  "version": "0.0.1",
  "description": "Shopee Affiliate node for n8n",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist",
    "nodes"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons && cp nodes/ShopeeAffiliate/*.svg dist/nodes/ShopeeAffiliate/",
    "buildAndRun": "docker compose down && docker compose build --no-cache && docker compose up",
    "test": "tsc && jest",
    "postinstall": "npx @socketsecurity/socket-patch apply --silent --ecosystems npm",
    "dependencies": "npx @socketsecurity/socket-patch apply --silent --ecosystems npm"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ShopeeAffiliateApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ShopeeAffiliate/ShopeeAffiliate.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "gulp": "^5.0.1",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "n8n-core": "^2.16.1",
    "n8n-workflow": "^2.16.0"
  }
}
