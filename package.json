{
  "name": "n8n-nodes-shopee-affiliate",
  "version": "0.0.1",
  "description": "Shopee Affiliate node for n8n",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",

  "main": "dist/index.js",

  "files": [
    "dist"
  ],

  "scripts": {
    "build": "tsc && gulp build:icons"
  },

  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ShopeeAffiliateApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ShopeeAffiliate/ShopeeAffiliate.node.js"
    ]
  },

  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "gulp": "^4.0.2",
    "typescript": "^5.8.3"
  },

  "dependencies": {
    "n8n-core": "^1.82.0",
    "n8n-workflow": "^1.82.0"
  }
}