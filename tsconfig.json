{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",

    "lib": [
      "ES2022"
    ],

    "moduleResolution": "node",

    "declaration": true,

    "sourceMap": true,

    "outDir": "dist",

    "strict": false,

    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": [
    "credentials/**/*.ts",
    "nodes/**/*.ts"
  ]
}